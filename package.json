{
  "name": "velo-backend",
  "version": "1.0.0",
  "description": "Express TypeScript backend with TypeORM and PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "test": "jest --runInBand",
    "seed:pricing": "ts-node src/scripts/seed-vehicle-pricing.ts",
    "backfill:locations": "ts-node src/scripts/backfill-merchant-locations.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": {
            "rootDir": ".",
            "experimentalDecorators": true,
            "emitDecoratorMetadata": true,
            "strict": false
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(uuid)/)"
    ],
    "moduleNameMapper": {
      ".*/db/data-source$": "<rootDir>/tests/__mocks__/data-source.ts",
      "^uuid$": "<rootDir>/tests/__mocks__/uuid.ts",
      "^expo-server-sdk$": "<rootDir>/tests/__mocks__/expo-server-sdk.ts",
      ".*/utils/supabase-client$": "<rootDir>/tests/__mocks__/supabase-client.ts"
    },
    "setupFiles": [
      "<rootDir>/tests/setup-env.ts"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@prelude.so/sdk": "^0.10.0",
    "@supabase/supabase-js": "^2.97.0",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "ioredis": "^5.10.0",
    "libphonenumber-js": "^1.12.38",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.8.3",
    "stripe": "^21.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
